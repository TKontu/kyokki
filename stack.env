# Kyokki Production Environment
# Fill in real values in Portainer stack environment editor.
# Do NOT commit real secrets to git.

# Database
POSTGRES_PASSWORD=change_me

# MinerU OCR (homelab)
MINERU_BASE_URL=http://192.168.0.136:8000
MINERU_TIMEOUT=60
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=false

# LLM Service (homelab vLLM/Ollama)
LLM_BASE_URL=http://192.168.0.247:9003/v1
LLM_API_KEY=ollama
LLM_MODEL=Qwen3-4B-Instruct
LLM_TEMPERATURE=0.1

# Open Food Facts (public API, no key needed)
OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v2

# Fuzzy matching
FUZZY_MATCH_THRESHOLD=80
